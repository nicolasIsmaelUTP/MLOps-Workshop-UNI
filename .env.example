# Ruta al dataset crudo
DATA_RAW_PATH=data/raw/concrete_data.csv

# Ruta donde se guardará el modelo entrenado
MODEL_OUTPUT_PATH=models/modelo_concreto.joblib

# (Opcional) Configuración de MLflow / Databricks
# MLFLOW_TRACKING_URI=https://tu-instancia.databricks.com
# DATABRICKS_HOST=https://tu-instancia.databricks.com
# DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxx
